{
  "unique_id": "model.shop.dim_customers",
  "name": "dim_customers",
  "label": "Customers",
  "description": "One row per customer enriched with lifetime order totals.",
  "language": "en",
  "upstream": [
    {
      "name": "stg_customers",
      "label": "Cleaned Customers",
      "display_label": "Cleaned Customers",
      "resource_type": "model",
      "direct": true
    },
    {
      "name": "stg_orders",
      "label": "Cleaned Orders",
      "display_label": "Cleaned Orders",
      "resource_type": "model",
      "direct": true
    },
    {
      "name": "customers",
      "label": "Source Customers",
      "display_label": "Source Customers",
      "resource_type": "source",
      "direct": false
    },
    {
      "name": "orders",
      "label": "Source Orders",
      "display_label": "Source Orders",
      "resource_type": "source",
      "direct": false
    }
  ],
  "sql": "select c.customer_id, c.email, sum(o.amount) as lifetime_value, case when sum(o.amount) > 1000 then 'vip' else 'standard' end as status from \"warehouse\".\"analytics\".\"stg_customers\" c left join \"warehouse\".\"analytics\".\"stg_orders\" o on c.customer_id = o.customer_id group by 1, 2",
  "semantic_models": [
    {
      "name": "Customers",
      "dimensions": [
        "Customer Status",
        "Signup Date"
      ],
      "measures": [
        "Lifetime Value",
        "Customer Count"
      ]
    }
  ],
  "metrics": [
    {
      "name": "Total Lifetime Value",
      "type": "simple",
      "description": "The total amount spent across all customers."
    },
    {
      "name": "Customer Count",
      "type": "simple",
      "description": "The number of distinct customers."
    }
  ]
}
  "sql": "select c.customer_id, c.email, sum(o.amount) as lifetime_value, case when sum(o.amount) > 1000 then 'vip' else 'standard' end as status from \"warehouse\".\"analytics\".\"stg_customers\" c left join \"warehouse\".\"analytics\".\"stg_orders\" o on c.customer_id = o.customer_id group by 1, 2",
  "sql_source": "compiled",
  "semantic_models": [
    {
      "name": "Customers",
      "dimensions": [
        "Customer Status",
        "Signup Date"
      ],
      "measures": [
        "Lifetime Value",
        "Customer Count"
      ]
    }
  ],
  "metrics": [
    {
      "name": "Total Lifetime Value",
      "type": "simple",
      "description": "The total amount spent across all customers."
    },
    {
      "name": "Customer Count",
      "type": "simple",
      "description": "The number of distinct customers."
    }
  ],
